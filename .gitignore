/target
**/*.rs.bk

# OS
.DS_Store

# Environment & secrets
.env
.env.*
*.pem

# Config files (only example.toml is tracked)
config/*.toml
!config/example.toml

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local dev data (SurrealDB file-based mode, RustFS local storage)
data/

# Complement test results
complement-results.json

# Claude Code
.claude/

# Product spec (internal)
maelstrom-product-spec.md
history.txt
